<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".viewmodel.InternNepalApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.InternNepal"
        tools:replace="android:fullBackupContent">

        <!-- Launcher Activity with Splash Theme -->
        <activity
            android:name=".view.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.InternNepal.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Other Activities -->
        <activity
            android:name=".view.RegisterActivity"
            android:exported="false"
            android:label="@string/title_activity_register"
            android:theme="@style/Theme.InternNepal" />

        <activity
            android:name=".view.admin.AdminRegisterActivity"
            android:exported="false"
            android:label="Admin Registration"
            android:theme="@style/Theme.InternNepal" />

        <activity
            android:name=".view.ForgotPasswordActivity"
            android:exported="false"
            android:label="Forgot Password"
            android:theme="@style/Theme.InternNepal" />

        <activity
            android:name=".view.user.UserDashboardActivity"
            android:exported="false"
            android:label="Dashboard"
            android:theme="@style/Theme.InternNepal" />

        <activity
            android:name=".view.AdminDashboardActivity"
            android:exported="false"
            android:label="Admin Dashboard"
            android:theme="@style/Theme.InternNepal" />

        <activity
            android:name=".view.MainActivity"
            android:exported="false" />

    </application>

</manifest>
